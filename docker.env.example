# Server Configuration
PORT=5001
NODE_ENV=production

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# EVE Frontier API Configuration
EVE_FRONTIER_API_URL=https://world-api-nova.live.tech.evefrontier.com
EVE_FRONTIER_API_KEY=your_api_key_here

# Database Configuration
# If using an external database instead of SQLite
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=eve_starmap
# DB_USER=postgres
# DB_PASSWORD=postgres

# Client Configuration 
# Used by docker-compose to properly configure the frontend
API_URL=http://server:5001

# WebSocket Configuration
WS_ENDPOINT=/ws

# Service Schedules
# Cron-like schedule for risk data updates (default: every 5 minutes)
RISK_UPDATE_SCHEDULE="*/5 * * * *"
# Cron-like schedule for system details updates (default: hourly)
SYSTEM_DETAILS_UPDATE_SCHEDULE="0 * * * *"

# Logging Configuration
LOG_LEVEL=info
# Set to true to enable detailed debug logging
DEBUG=false 